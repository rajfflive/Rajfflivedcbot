{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "nixpacksPlan": {
      "phases": {
        "setup": {
          "nixPkgs": ["ffmpeg", "python313", "python313Packages.pip"]
        },
        "install": {
          "cmds": [
            "ln -sf $(which ffmpeg) /usr/local/bin/ffmpeg || true",
            "python3.13 -m pip install -r requirements.txt"
          ]
        }
      }
    }
  },
  "deploy": {
    "startCommand": "python3.13 main.py",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 5
  }
}
